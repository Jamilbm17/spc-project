meta {
  name: Inscribirse a Actividad
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/enrollments
  body: json
  auth: bearer
}

auth:bearer {
  token: {{studentToken}}
}

body:json {
  {
    "activityId": 1
  }
}

script:post-response {
  const data = res.getBody();
  if (data.id) {
    bru.setEnvVar("enrollmentId", data.id);
  }
}

docs {
  Inscribe al estudiante autenticado en una actividad.
  Requiere token de estudiante (`studentToken`).
  El ID de la inscripción se guarda en `enrollmentId`.
}
