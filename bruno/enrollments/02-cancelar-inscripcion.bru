meta {
  name: Cancelar Inscripción
  type: http
  seq: 2
}

delete {
  url: {{baseUrl}}/enrollments/{{enrollmentId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{studentToken}}
}

docs {
  Cancela la inscripción del estudiante autenticado.
  Solo puede cancelar sus propias inscripciones. Usa la variable `enrollmentId`.
}
