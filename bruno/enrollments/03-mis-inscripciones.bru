meta {
  name: Mis Inscripciones
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/enrollments/my
  body: none
  auth: bearer
}

auth:bearer {
  token: {{studentToken}}
}

docs {
  Retorna todas las inscripciones activas del estudiante autenticado.
  Requiere token de estudiante (`studentToken`).
}
